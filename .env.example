# 主模型提供方
AI_PROVIDER=minimax

# 论文主写作模型
MINIMAX_MODEL=MiniMax-M2.7

# OpenAI 兼容 API 基地址
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 请在本地自行填写，不要提交到仓库
MINIMAX_API_KEY=

# 是否启用联网搜索工具层
ENABLE_WEB_SEARCH=true

# 搜索工具模式：
# minimax_mcp = 走 MiniMax 官方 MCP 搜索工具链
# custom = 你自己接搜索 API / 浏览器工具
WEB_SEARCH_MODE=minimax_mcp

# 如果后面接官方 MCP，可在本地补这些
SERPER_API_KEY=
JINA_API_KEY=
